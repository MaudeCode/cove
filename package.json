{
  "name": "@maudecode/cove",
  "version": "2026.3.13",
  "description": "A beautiful, full-featured WebUI for OpenClaw",
  "type": "module",
  "license": "MIT",
  "author": "Kilian Tyler <kilian@kil.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaudeCode/cove.git"
  },
  "homepage": "https://github.com/MaudeCode/cove#readme",
  "bugs": {
    "url": "https://github.com/MaudeCode/cove/issues"
  },
  "keywords": [
    "openclaw",
    "webui",
    "chat",
    "ai",
    "assistant"
  ],
  "bin": {
    "@maudecode/cove": "./bin/cove.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "dev:prod": "node bin/cove.js",
    "build": "tsc -b && vite build",
    "test": "bun run test:all",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:deployment": "COVE_RUN_DOCKER_SMOKE=1 bun test tests/integration/deployment",
    "test:package": "COVE_RUN_PACKAGE_INTEGRITY=1 bun test tests/integration/package",
    "test:e2e": "playwright test",
    "test:all": "bun run test:unit && bun run test:integration && bun run test:e2e",
    "test:coverage": "bun test --coverage tests/unit tests/integration",
    "preview": "vite preview",
    "lint": "oxlint src/ tests/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint:fix": "oxlint src/ tests/ --fix",
    "format": "oxfmt --write src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "typecheck": "tsc -b --noEmit",
    "worktree:bootstrap": "bash scripts/bootstrap-worktree.sh",
    "knip": "knip",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run i18n:check && bun run test:all && bun run knip",
    "i18n:check": "bun scripts/check-i18n.ts",
    "i18n:fix": "bun scripts/check-i18n.ts --fix",
    "prepare": "husky",
    "serve": "bun run server.ts",
    "start": "NODE_ENV=production bun run server.ts",
    "server": "bun run server.ts"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/opendyslexic": "^5.2.5",
    "@fontsource/source-code-pro": "^5.2.7",
    "@preact/signals": "^2.8.1",
    "dompurify": "^3.3.1",
    "lucide-preact": "^0.563.0",
    "marked": "^17.0.3",
    "preact": "^10.28.3",
    "preact-router": "^4.1.2",
    "prismjs": "^1.30.0",
    "simple-icons": "^16.9.0",
    "tokenx": "^1.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@playwright/test": "^1.60.0",
    "@preact/preset-vite": "^2.10.3",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.3.0",
    "@types/prismjs": "^1.26.6",
    "conventional-changelog-cli": "^5.0.0",
    "happy-dom": "^20.10.3",
    "husky": "^9.1.7",
    "knip": "^5.84.1",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.48.0",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4"
  },
  "knip": {
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "ignoreExportsUsedInFile": true,
    "entry": [
      "src/main.tsx",
      "src/lib/utils.ts",
      "src/lib/i18n.ts",
      "src/locales/index.ts"
    ],
    "ignore": [
      "src/signals/agents.ts"
    ]
  }
}
